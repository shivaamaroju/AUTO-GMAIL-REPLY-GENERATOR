{
  "manifest_version": 3,
  "name": "Gmail AI Reply Extension",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "action": {
      "default_popup": "popup.html"
  },
  "background": {
      "service_worker": "background.js"
  },
  "content_scripts": [
      {
          "matches": ["https://mail.google.com/*"],
          "js": ["content.js"]
      }
  ]
}
